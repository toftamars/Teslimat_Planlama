<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Google Routes API (trafik sıralaması). Anahtar boş bırakılır; yönetici doldurur. -->
        <record id="param_google_maps_api_key" model="ir.config_parameter">
            <field name="key">teslimat_planlama.google_maps_api_key</field>
            <field name="value"></field>
        </record>
        <!-- Depo / çıkış noktası (rota başlangıcı) -->
        <record id="param_rota_baslangic_adres" model="ir.config_parameter">
            <field name="key">teslimat_planlama.rota_baslangic_adres</field>
            <field name="value">İstanbul, Türkiye</field>
        </record>
    </data>
</odoo>
