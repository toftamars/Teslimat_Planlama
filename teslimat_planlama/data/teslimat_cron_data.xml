<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Gün dönümünde araç kapasite alanlarını (mevcut_kapasite/kalan_kapasite)
            tazeler. Bu alanlar 'bugün'e bağlı + store=True olduğundan @api.depends
            ile gece yarısı otomatik güncellenemez; bu cron tazeliği garanti eder.
            noupdate="1": yöneticinin zaman/aktiflik ayarı upgrade'de korunur.
        -->
        <record id="ir_cron_recompute_arac_kapasite" model="ir.cron">
            <field name="name">Teslimat: Araç Kapasitesini Tazele (gün dönümü)</field>
            <field name="model_id" ref="model_teslimat_arac"/>
            <field name="state">code</field>
            <field name="code">model._cron_recompute_kapasite()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall"
                   eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')"/>
        </record>
    </data>
</odoo>
