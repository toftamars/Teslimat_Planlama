<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Teslimat Belgesi Views -->
    
    <!-- Kanban View -->
    <record id="view_teslimat_belgesi_kanban" model="ir.ui.view">
        <field name="name">teslimat.belgesi.kanban</field>
        <field name="model">teslimat.belgesi</field>
        <field name="arch" type="xml">
            <kanban default_group_by="durum" class="o_kanban_dashboard">
                <field name="name"/>
                <field name="teslimat_tarihi"/>
                <field name="musteri_id"/>
                <field name="arac_id"/>
                <field name="ilce_id"/>
                <field name="durum"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><field name="musteri_id"/></div>
                                    <div><field name="ilce_id"/> - <field name="arac_id"/></div>
                                    <div><field name="teslimat_tarihi"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_teslimat_belgesi_tree" model="ir.ui.view">
        <field name="name">teslimat.belgesi.tree</field>
        <field name="model">teslimat.belgesi</field>
        <field name="arch" type="xml">
            <tree string="Teslimat Belgeleri" create="false" delete="0" decoration-info="durum == 'hazir'" decoration-success="durum == 'teslim_edildi'" decoration-danger="durum == 'iptal'">
                <field name="name"/>
                <field name="teslimat_tarihi"/>
                <field name="musteri_id"/>
                <field name="arac_id"/>
                <field name="ilce_id"/>
                <field name="location_id" string="Depo"/>
                <field name="durum" widget="badge" decoration-success="durum == 'teslim_edildi'" decoration-info="durum == 'hazir'" decoration-warning="durum == 'yolda'" decoration-danger="durum == 'iptal'"/>
                <field name="transfer_no"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_teslimat_belgesi_form" model="ir.ui.view">
        <field name="name">teslimat.belgesi.form</field>
        <field name="model">teslimat.belgesi</field>
        <field name="arch" type="xml">
            <form string="Teslimat Belgesi" create="false">
                <header>
                    <!-- Sürücü: Yolda Butonu (sadece hazir durumunda görünür) -->
                    <button name="action_yolda_yap" string="🚗 Yolda" type="object"
                            class="oe_highlight" icon="fa-road"
                            attrs="{'invisible': [('durum', '!=', 'hazir')]}"
                            groups="teslimat_planlama.group_teslimat_driver"/>

                    <!-- Sürücü: Yol Tarifi (sadece yolda durumunda görünür) -->
                    <button name="action_yol_tarifi" string="🗺️ Yol Tarifi" type="object"
                            class="btn-primary" icon="fa-map-marker"
                            attrs="{'invisible': [('durum', '!=', 'yolda')]}"
                            groups="teslimat_planlama.group_teslimat_driver"/>

                    <!-- Sürücü: Teslimatı Tamamla (sadece yolda durumunda görünür) -->
                    <button name="action_teslimat_tamamla" string="✅ Teslimatı Tamamla" type="object" 
                            class="oe_highlight" icon="fa-check"
                            attrs="{'invisible': [('durum', '!=', 'yolda')]}"
                            groups="teslimat_planlama.group_teslimat_driver"/>

                    <!-- İptal Et: yalnızca yönetici veya transferi oluşturan görür/görebilir -->
                    <button name="action_iptal_et" string="❌ İptal Et" type="object"
                            class="btn-danger" icon="fa-times-circle"
                            attrs="{'invisible': [('durum', 'in', ['teslim_edildi', 'iptal']), ('can_user_cancel', '=', False)]}"
                            confirm="Bu teslimatı iptal etmek istediğinizden emin misiniz?"/>

                    <field name="durum" widget="statusbar" 
                           statusbar_visible="taslak,bekliyor,hazir,yolda,teslim_edildi"
                           clickable="False"/>
                </header>
                <sheet>
                    <field name="is_readonly" invisible="1"/>
                    <field name="can_user_cancel" invisible="1"/>
                    
                    <!-- Teslim Edildi Uyarısı -->
                    <div class="alert alert-success" role="alert" attrs="{'invisible': [('is_readonly', '=', False)]}">
                        <strong>✅ Teslimat Tamamlandı</strong> - Bu belge teslim edilmiştir ve düzenlenemez.
                    </div>
                    
                    <!-- Yönetici Bilgilendirme -->
                    <div class="alert alert-info" role="alert" groups="teslimat_planlama.group_teslimat_manager" attrs="{'invisible': [('durum', '=', 'teslim_edildi')]}">
                        <strong>👑 Yönetici Modu</strong> - Sınırsız teslimat oluşturabilir, tüm kısıtlamaları bypass edebilirsiniz.
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Teslimat No"/>
                        </h1>
                    </div>
                    <group attrs="{'readonly': [('is_readonly', '=', True)]}">
                        <group>
                            <field name="teslimat_tarihi"/>
                            <field name="stock_picking_id"/>
                            <field name="transfer_no"/>
                            <field name="location_id" string="Depo"/>
                            <field name="transfer_olusturan_id" string="Sorumlu Personel" options="{'no_create': True}"/>
                            <field name="analytic_account_id" string="Analitik hesap" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="arac_id"/>
                            <field name="ilce_id"/>
                        </group>
                    </group>
                    <group attrs="{'readonly': [('is_readonly', '=', True)]}">
                        <group string="📞 Müşteri İletişim Bilgileri">
                            <field name="musteri_id"/>
                            <field name="musteri_telefon" widget="phone" 
                                   string="📞 Müşteri Telefonu"/>
                            <field name="manuel_telefon" widget="phone"
                                   string="📱 Telefon (Opsiyonel)"
                                   attrs="{'invisible': [('manuel_telefon', '=', False)]}"
                                   help="Wizard'dan girilen opsiyonel telefon numarası"/>
                            <field name="musteri_adres" 
                                   string="📍 Müşteri Adresi"
                                   attrs="{'invisible': [('musteri_adres', '=', False)]}"
                                   widget="text"
                                   placeholder="Adres bilgisi yükleniyor..."/>
                        </group>
                        <group>
                            <field name="sira_no" readonly="1"/>
                        </group>
                    </group>
                    <group string="Transfer Ürünleri">
                        <field name="transfer_urun_ids" readonly="1">
                            <tree editable="false">
                                <field name="sequence"/>
                                <field name="urun_id"/>
                                <field name="miktar"/>
                                <field name="birim"/>
                                <field name="stock_move_id" invisible="1"/>
                            </tree>
                        </field>
                    </group>
                    <group string="Teslim Bilgileri" attrs="{'invisible': [('durum', '!=', 'teslim_edildi')]}">
                        <group>
                            <field name="teslim_alan_kisi" readonly="1"/>
                            <field name="gercek_teslimat_saati" readonly="1"/>
                        </group>
                        </group>
                    
                    <!-- Teslimat Fotoğrafı -->
                    <group string="📷 Teslimat Fotoğrafı" attrs="{'invisible': ['|', ('durum', '!=', 'teslim_edildi'), ('teslimat_fotografi', '=', False)]}">
                        <div class="text-center">
                            <field name="teslimat_fotografi" widget="image" readonly="1" nolabel="1" 
                                   options="{'size': [600, 600]}"
                                   class="oe_avatar"
                                   style="cursor: pointer; max-width: 100%; height: auto;"
                                   title="Fotoğrafa tıklayarak büyütebilirsiniz"/>
                            <field name="fotograf_dosya_adi" invisible="1"/>
                            <p class="text-muted mt-2">
                                <i class="fa fa-info-circle"/> Fotoğrafa tıklayarak tam boyutta görüntüleyebilirsiniz
                            </p>
                        </div>
                    </group>
                    
                    <group string="Notlar" attrs="{'readonly': [('is_readonly', '=', True)]}">
                        <field name="notlar" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_teslimat_belgesi_search" model="ir.ui.view">
        <field name="name">teslimat.belgesi.search</field>
        <field name="model">teslimat.belgesi</field>
        <field name="arch" type="xml">
            <search string="Teslimat Belgesi Arama">
                <field name="name"/>
                <field name="teslimat_tarihi"/>
                <field name="musteri_id"/>
                <field name="arac_id"/>
                <field name="ilce_id"/>
                <field name="surucu_id"/>
                <field name="transfer_no"/>
                <field name="durum"/>
                <filter string="Bugün" name="bugun" domain="[('teslimat_tarihi','=',context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Bu Hafta" name="bu_hafta" domain="[('teslimat_tarihi','>=',(context_today()-datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="Taslak" name="taslak" domain="[('durum','=','taslak')]"/>
                <filter string="Bekliyor" name="bekliyor" domain="[('durum','=','bekliyor')]"/>
                <filter string="Hazır" name="hazir" domain="[('durum','=','hazir')]"/>
                <filter string="Yolda" name="yolda" domain="[('durum','=','yolda')]"/>
                <filter string="Teslim Edildi" name="teslim_edildi" domain="[('durum','=','teslim_edildi')]"/>
                <group expand="0" string="Grupla">
                    <filter string="Tarih" name="group_tarih" context="{'group_by': 'teslimat_tarihi'}"/>
                    <filter string="Araç" name="group_arac" context="{'group_by': 'arac_id'}"/>
                    <filter string="İlçe" name="group_ilce" context="{'group_by': 'ilce_id'}"/>
                    <filter string="Durum" name="group_durum" context="{'group_by': 'durum'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_teslimat_belgesi" model="ir.actions.act_window">
        <field name="name">Teslimat Belgeleri</field>
        <field name="res_model">teslimat.belgesi</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{'create': False, 'search_default_bugun': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Henüz teslimat belgesi oluşturulmamış
            </p>
            <p>
                Teslimat belgesi oluşturmak için <strong>Kapasite Sorgulama</strong> üzerinden uygun bir tarih seçin.
            </p>
        </field>
    </record>

    <!-- Sil (yalnızca yönetici): Aksiyon menüsünde sadece Teslimat Yöneticisi grubundakiler görür -->
    <record id="action_teslimat_belgesi_sil_yonetici" model="ir.actions.server">
        <field name="name">Sil</field>
        <field name="model_id" ref="model_teslimat_belgesi"/>
        <field name="binding_model_id" ref="model_teslimat_belgesi"/>
        <field name="binding_view_types">list</field>
        <field name="groups_id" eval="[(4, ref('teslimat_planlama.group_teslimat_manager'))]"/>
        <field name="state">code</field>
        <field name="code">action = records.unlink()</field>
    </record>

    <!-- Rota optimizasyonu: Seçili teslimatların adreslerini Google Maps çoklu durak ile aç -->
    <record id="action_teslimat_belgesi_rota_optimizasyonu" model="ir.actions.server">
        <field name="name">🗺️ Rota Optimizasyonu Oluştur</field>
        <field name="model_id" ref="model_teslimat_belgesi"/>
        <field name="binding_model_id" ref="model_teslimat_belgesi"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_rota_optimizasyonu()</field>
    </record>
</odoo>

