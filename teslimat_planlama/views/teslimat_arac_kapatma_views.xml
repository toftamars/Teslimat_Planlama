<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Araç Kapatma Tree View -->
    <record id="view_teslimat_arac_kapatma_tree" model="ir.ui.view">
        <field name="name">teslimat.arac.kapatma.tree</field>
        <field name="model">teslimat.arac.kapatma</field>
        <field name="arch" type="xml">
            <list string="Araç Kapatma Kayıtları" 
                  decoration-danger="not aktif"
                  decoration-warning="aktif"
                  decoration-success="not aktif">
                <field name="arac_id"/>
                <field name="baslangic_tarihi"/>
                <field name="bitis_tarihi"/>
                <field name="gun_sayisi" string="Gün"/>
                <field name="sebep"/>
                <field name="kapatan_kullanici_id"/>
                <field name="aktif" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Araç Kapatma Form View -->
    <record id="view_teslimat_arac_kapatma_form" model="ir.ui.view">
        <field name="name">teslimat.arac.kapatma.form</field>
        <field name="model">teslimat.arac.kapatma</field>
        <field name="arch" type="xml">
            <form string="Araç Kapatma Detayı">
                <header>
                    <button name="action_iptal_et" string="İptal Et" type="object" 
                            class="btn-warning"
                            invisible="not aktif"/>
                    <button name="action_aktif_et" string="Tekrar Aktif Et" type="object" 
                            class="btn-success"
                            invisible="aktif"/>
                    <field name="aktif" widget="statusbar" statusbar_visible="1"/>
                </header>
                
                <sheet>
                    <!-- Uyarı Mesajı - Kapalı kayıt -->
                    <div class="alert alert-danger" role="alert" invisible="aktif">
                        <i class="fa fa-ban"/> Bu kapatma kaydı <strong>iptal edilmiş</strong>
                    </div>
                    
                    <!-- Uyarı Mesajı - Aktif kapatma -->
                    <div class="alert alert-warning" role="alert" 
                         invisible="not aktif">
                        <i class="fa fa-exclamation-triangle"/> Bu araç <strong>kapalı</strong>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="📅 Tarih Bilgileri">
                            <field name="baslangic_tarihi"/>
                            <field name="bitis_tarihi"/>
                            <field name="gun_sayisi" readonly="1"/>
                        </group>
                        <group string="🚗 Araç Bilgileri">
                            <field name="arac_id" options="{'no_create': True}"/>
                            <field name="sebep"/>
                        </group>
                    </group>
                    
                    <group string="📝 Açıklama">
                        <field name="aciklama" nolabel="1" placeholder="Detaylı açıklama giriniz..."/>
                    </group>
                    
                    <group>
                        <group string="👤 Sistem Bilgileri">
                            <field name="kapatan_kullanici_id" readonly="1"/>
                            <field name="olusturma_tarihi" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Araç Kapatma Search View -->
    <record id="view_teslimat_arac_kapatma_search" model="ir.ui.view">
        <field name="name">teslimat.arac.kapatma.search</field>
        <field name="model">teslimat.arac.kapatma</field>
        <field name="arch" type="xml">
            <search string="Araç Kapatma Ara">
                <field name="arac_id"/>
                <field name="sebep"/>
                <field name="kapatan_kullanici_id"/>
                
                <filter string="Aktif" name="filter_aktif" domain="[('aktif', '=', True)]"/>
                <filter string="İptal Edilmiş" name="filter_iptal" domain="[('aktif', '=', False)]"/>
                
                <separator/>
                <filter string="Devam Eden" name="filter_devam_eden" 
                        domain="[('baslangic_tarihi', '&lt;=', context_today()), ('bitis_tarihi', '&gt;=', context_today()), ('aktif', '=', True)]"/>
                <filter string="Geçmiş" name="filter_gecmis" 
                        domain="[('bitis_tarihi', '&lt;', context_today())]"/>
                <filter string="Gelecek" name="filter_gelecek" 
                        domain="[('baslangic_tarihi', '&gt;', context_today())]"/>
                
                <separator/>
                <group expand="0" string="Grupla">
                    <filter string="Araç" name="group_arac" context="{'group_by': 'arac_id'}"/>
                    <filter string="Sebep" name="group_sebep" context="{'group_by': 'sebep'}"/>
                    <filter string="Başlangıç Tarihi" name="group_baslangic" context="{'group_by': 'baslangic_tarihi'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_teslimat_arac_kapatma" model="ir.actions.act_window">
        <field name="name">Araç Kapatma Kayıtları</field>
        <field name="res_model">teslimat.arac.kapatma</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_aktif': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Henüz araç kapatma kaydı yok
            </p>
            <p>
                Araçları belirli günlerde kapatabilir (bakım, arıza, vb.) ve bu günler otomatik olarak "Uygun Günler" listesinde görünür.
            </p>
        </field>
    </record>
</odoo>
