<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Teslimat Belgesi Wizard Views -->
    
    <record id="view_teslimat_belgesi_wizard_form" model="ir.ui.view">
        <field name="name">teslimat.belgesi.wizard.form</field>
        <field name="model">teslimat.belgesi.wizard</field>
        <field name="arch" type="xml">
            <form string="Teslimat Belgesi Oluştur">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span>📋 Teslimat Belgesi Oluştur</span>
                        </h1>
                    </div>
                    <!-- Temel Bilgiler -->
                    <group>
                        <group>
                            <field name="teslimat_tarihi" readonly="1" force_save="1"/>
                            <field name="arac_id" 
                                   force_save="1"
                                   domain="[('aktif','=',True),('gecici_kapatma','=',False)]"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="arac_kucuk_mu" invisible="1"/>
                            <field name="ilce_id"
                                   force_save="1"
                                   options="{'no_create': True, 'no_edit': True}"
                                   required="arac_id and not arac_kucuk_mu"/>
                        </group>
                    </group>
                    <!-- Transfer No -->
                    <group>
                        <field name="transfer_id"
                               options="{'no_create': True}"
                               placeholder="DEPO/OUT/00085 yazarak arayın"
                               required="1"/>
                        <field name="transfer_olusturan_id" string="Sorumlu Personel" options="{'no_create': True}"/>
                        <field name="analytic_account_id" string="Analitik hesap" options="{'no_create': True}"/>
                    </group>
                    <group string="Not (Opsiyonel)">
                        <field name="wizard_notu" nolabel="1" placeholder="Buraya yazdığınız notlar oluşturulan teslimat belgesinde görünür..."/>
                    </group>
                    <!-- Müşteri ve Adres (otomatik) -->
                    <group string="Müşteri Bilgileri">
                        <group>
                            <field name="musteri_id" readonly="1" force_save="1"/>
                            <field name="adres" readonly="1"/>
                        </group>
                        <group>
                            <field name="musteri_telefon" readonly="1" widget="phone"/>
                            <field name="manuel_telefon" widget="phone" placeholder="İsteğe bağlı - farklı telefon girebilirsiniz"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_teslimat_olustur" string="✅ Teslimat Belgesi Oluştur" 
                            type="object" class="btn-primary"/>
                    <button string="❌ İptal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

