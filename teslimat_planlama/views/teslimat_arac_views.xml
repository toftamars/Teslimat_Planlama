<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Teslimat Araç Views -->
    
    <!-- Tree View -->
    <record id="view_teslimat_arac_tree" model="ir.ui.view">
        <field name="name">teslimat.arac.tree</field>
        <field name="model">teslimat.arac</field>
        <field name="arch" type="xml">
            <tree string="Araçlar">
                <header>
                    <button name="action_sync_all_arac_ilce" string="🔄 Tüm Araç-İlçe Eşleştirmelerini Güncelle" 
                            type="object" 
                            class="btn-primary"
                            groups="teslimat_planlama.group_teslimat_manager"
                            help="Tüm araçların ilçe eşleştirmelerini araç tipine göre otomatik günceller"/>
                </header>
                <field name="name"/>
                <field name="arac_tipi"/>
                <field name="gunluk_teslimat_limiti" groups="teslimat_planlama.group_teslimat_manager"/>
                <field name="mevcut_kapasite"/>
                <field name="kalan_kapasite"/>
                <field name="aktif"/>
                <button name="action_update_uygun_ilceler" string="🔄 İlçeleri Güncelle" type="object"
                        class="btn-info"
                        groups="teslimat_planlama.group_teslimat_manager"
                        help="Bu aracın ilçe eşleştirmesini güncelle"/>
                <button name="action_gecici_kapat" string="Kapat" type="object"
                        class="btn-secondary"
                        groups="teslimat_planlama.group_teslimat_manager"/>
            </tree>
        </field>
    </record>

    <!-- Form View (sadece yönetici grubu) -->
    <record id="view_teslimat_arac_form" model="ir.ui.view">
        <field name="name">teslimat.arac.form</field>
        <field name="model">teslimat.arac</field>
        <field name="groups_id" eval="[(4, ref('teslimat_planlama.group_teslimat_manager'))]"/>
        <field name="arch" type="xml">
            <form string="Teslimat Aracı">
                <header>
                    <button name="action_update_uygun_ilceler" string="🔄 İlçe Eşleştirmesini Güncelle" type="object" 
                            class="btn-info"
                            groups="teslimat_planlama.group_teslimat_manager"
                            help="Araç tipine göre uygun ilçeleri otomatik günceller"/>
                    <button name="action_gecici_kapat" string="Geçici Kapat" type="object"
                            class="btn-secondary"
                            groups="teslimat_planlama.group_teslimat_manager"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Araç Adı"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="arac_tipi"/>
                            <field name="aktif"/>
                        </group>
                        <group>
                            <field name="gunluk_teslimat_limiti" 
                                   groups="teslimat_planlama.group_teslimat_manager"/>
                            <field name="mevcut_kapasite" readonly="1"/>
                            <field name="kalan_kapasite" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Uygun İlçeler">
                            <field name="uygun_ilceler" widget="many2many_tags" 
                                   readonly="1" 
                                   groups="!teslimat_planlama.group_teslimat_manager"/>
                            <field name="uygun_ilceler" widget="many2many_tags" 
                                   groups="teslimat_planlama.group_teslimat_manager"/>
                            <p class="text-muted">
                                <strong>Otomatik Eşleştirme:</strong> Araç tipine göre uygun ilçeler otomatik olarak belirlenir.
                                <br/>
                                • <strong>Anadolu Yakası</strong> araçları → Sadece Anadolu Yakası ilçeleri
                                <br/>
                                • <strong>Avrupa Yakası</strong> araçları → Sadece Avrupa Yakası ilçeleri
                                <br/>
                                • <strong>Küçük araçlar ve ek araç</strong> → Tüm ilçelere gidebilir
                                <br/>
                                <br/>
                                <em>Yöneticiler manuel olarak düzenleyebilir, ancak sistem constraint ile kontrol eder.</em>
                            </p>
                        </page>
                        <page string="Teslimatlar">
                            <field name="teslimat_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="teslimat_tarihi"/>
                                    <field name="musteri_id"/>
                                    <field name="ilce_id"/>
                                    <field name="durum"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_teslimat_arac_search" model="ir.ui.view">
        <field name="name">teslimat.arac.search</field>
        <field name="model">teslimat.arac</field>
        <field name="arch" type="xml">
            <search string="Araç Arama">
                <field name="name"/>
                <field name="arac_tipi"/>
                <filter string="Aktif" name="aktif" domain="[('active','=',True)]"/>
                <filter string="Arşivlendi" name="archived" domain="[('active','=',False)]"/>
                <filter string="Kapasitesi Var" name="kapasite_var" domain="[('kalan_kapasite','>',0)]"/>
            </search>
        </field>
    </record>

    <!-- Action (sadece yönetici grubu) -->
    <record id="action_teslimat_arac" model="ir.actions.act_window">
        <field name="name">Teslimat Araçları</field>
        <field name="res_model">teslimat.arac</field>
        <field name="groups_id" eval="[(4, ref('teslimat_planlama.group_teslimat_manager'))]"/>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_aktif': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Henüz araç eklenmemiş
            </p>
            <p>
                Teslimat araçlarını buradan yönetebilirsiniz.
            </p>
            <p>
                <strong>Kapasite Yönetimi:</strong> Yöneticiler araç kapasitelerini ayarlayabilir.
                Varsayılan günlük teslimat limiti: 7 (user grubu için).
            </p>
        </field>
    </record>
</odoo>

